DASHSCOPE_API_KEY=<your key>
DASHSCOPE_BASE_URL=<the URL matching your key's region>
# Qwen3-TTS-Flash (agents/voiceover_caption_agent.py) is a SEPARATE credential
# pair, confirmed via live de-risk testing (derisk/test_tts_smoke.py) to live
# on a different DashScope region/workspace than text/vision/video on this
# account: DASHSCOPE_API_KEY returns a real "model_not_found" for every TTS
# model tried (native SDK and OpenAI-compatible endpoint alike), while a
# dedicated Singapore/dashscope-intl key works. Set BOTH of these -- there is
# no fallback to the vars above. DASHSCOPE_TTS_BASE_URL is set in the same
# `.../compatible-mode/v1` flavor as DASHSCOPE_BASE_URL for consistency; the
# module derives the native `.../api/v1` path from it internally (same host,
# different path -- see that module's docstring).
DASHSCOPE_TTS_API_KEY=<your TTS-scoped key -- confirm which region/workspace via the DashScope console before assuming it matches DASHSCOPE_API_KEY's region>
DASHSCOPE_TTS_BASE_URL=<the compatible-mode URL matching your TTS key's region, e.g. https://dashscope-intl.aliyuncs.com/compatible-mode/v1>
MODEL_TEXT=qwen3.7-plus
MODEL_TTS=qwen3-tts-flash
MODEL_VIDEO=wan2.6-i2v-us
# Wan2.6-i2v-us (agents/video_gen_node.py) uses the NATIVE dashscope SDK, not
# the OpenAI-compatible client -- it needs the native `.../api/v1` path on
# the SAME host as DASHSCOPE_BASE_URL, not the `.../compatible-mode/v1` path.
# Confirmed live (derisk/test_video_gen.py): omitting this and relying on the
# SDK's own mainland default fails; setting it to the native path on this
# key's region succeeds. Optional in code (falls back to the SDK's own
# default if unset), but required in practice for a region-scoped key like
# this account's.
DASHSCOPE_VIDEO_BASE_URL=<the native (.../api/v1) URL matching DASHSCOPE_API_KEY's region, e.g. https://dashscope-us.aliyuncs.com/api/v1>
# Qwen-VL model id -- check your DashScope console for the real value.
# Like MODEL_VIDEO, this is region/account-scoped; do not assume a value
# that worked elsewhere will work on this account.
MODEL_VISION=qwen3-vl-plus
OSS_ENDPOINT=oss-us-east-1.aliyuncs.com
OSS_BUCKET=bucket_name
OSS_ACCESS_KEY_ID=<your RAM AccessKey ID>
OSS_ACCESS_KEY_SECRET=<your RAM AccessKey Secret>
DATABASE_URL=<Database connection string>
# Tavily Extract API — used by brand_research_node to pull clean content from
# the brand's product page URL. If unset, falls back to a raw httpx fetch +
# HTML strip (works but misses JS-rendered pages). Get a key at tavily.com.
TAVILY_API_KEY=<your Tavily API key>

# ---------------------------------------------------------------------------
# International / Singapore region (video_gen_node.py intl path)
# Only required when deploying to the international DashScope region.
# All three must be set together — the node checks all three before routing
# a shot to the intl API. If any is unset the domestic path is used instead.
# ---------------------------------------------------------------------------
DASHSCOPE_VIDEO_INTL_API_KEY=<intl video API key from DashScope console>
DASHSCOPE_INTL_VIDEO_BASE_URL=<native .../api/v1 URL for intl region, e.g. https://dashscope-intl.aliyuncs.com/api/v1>
MODEL_VIDEO_INTL=<intl video model id, e.g. wan2.6-i2v-sg>
OSS_INTL_ENDPOINT=<intl OSS endpoint, e.g. oss-ap-southeast-1.aliyuncs.com>
OSS_INTL_BUCKET=<intl OSS bucket name>

# ---------------------------------------------------------------------------
# Optional tuning parameters (all have safe defaults; override as needed)
# ---------------------------------------------------------------------------
# Hero shot target duration window (shot_list_agent.py)
HERO_SHOT_MIN_DURATION_SEC=10.0
HERO_SHOT_MAX_DURATION_SEC=15.0
# How long to wait for video generation before timing out (video_gen_node.py)
VIDEO_GEN_WAIT_TIMEOUT_SEC=180
# Set to true to enable DashScope's server-side prompt expansion (video_gen_node.py)
VIDEO_GEN_PROMPT_EXTEND=false
# Fixed RNG seed for video generation reproducibility (video_gen_node.py); unset = random
# VIDEO_GEN_SEED=42
# TTS voice name (voiceover_caption_agent.py); "Cherry" confirmed working on intl account
TTS_VOICE=Cherry
# Drift threshold for continuity scoring — 0.0-1.0, lower = stricter (continuity_agent.py)
CONTINUITY_DRIFT_THRESHOLD=0.35
# Max automatic retries before requiring human review (continuity_gate.py)
CONTINUITY_MAX_AUTO_RETRIES=2
# Budget cap per job in USD if not set by the job submission form (budget_gate.py)
DEFAULT_JOB_BUDGET_CAP=2.00
# Path to a bold TTF font for caption overlays; Windows default below (assembly_agent.py)
# On Linux: /usr/share/fonts/truetype/liberation/LiberationSans-Bold.ttf
ASSEMBLY_CAPTION_FONT_PATH=C:/Windows/Fonts/arialbd.ttf
