# ProductCut frontend environment variables
#
# Copy this file to `.env.local` and adjust as needed:
#   cp .env.local.example .env.local
#
# Base URL (scheme + host + port, no trailing slash, no path) of the backend
# WebSocket server. The app connects to `${NEXT_PUBLIC_WS_BASE_URL}/ws/{job_id}`.
#
# Must be exposed to the browser, hence the required NEXT_PUBLIC_ prefix.
# Defaults to ws://localhost:8000 if unset.
NEXT_PUBLIC_WS_BASE_URL=ws://localhost:8000
